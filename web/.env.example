# Database Connection
# Replace with your actual database URLs (e.g. Vercel Postgres / Neon / local Docker)
# `DATABASE_URL` should be the pooled/runtime URL when available.
# `DATABASE_URL_UNPOOLED` should be the direct connection URL for Prisma Migrate/introspection.
# In local Postgres (no pooler), both can point to the same value.
DATABASE_URL="postgresql://user:password@localhost:5432/signage_db"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/signage_db"

# Next Auth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change_me_to_a_secure_random_string"
NEXTAUTH_URL="http://localhost:3000"

# Public API URL
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SCHEDULES_REDESIGN_ENABLED="false"

# Marketing lead forwarding webhook (optional)
# Example: Zapier, Make, n8n, Slack incoming webhook proxy, internal CRM endpoint
CONTACT_WEBHOOK_URL=""
# Timeout for webhook forwarding in milliseconds (default 5000, clamped 500-30000)
CONTACT_WEBHOOK_TIMEOUT_MS="5000"

# Distributed rate limiting (optional, recommended for production / multi-instance)
# If omitted, the app falls back to in-memory rate limiting (not shared between instances)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Optional override for local troubleshooting:
# RATE_LIMIT_BACKEND="memory"

# Debug API endpoints (disabled by default; enable only temporarily in local/private environments)
# Requires authenticated ADMIN session even when enabled.
# ENABLE_DEBUG_API_ROUTES="true"

# E2E (optional, required for credentialed Playwright flows)
E2E_BASE_URL="https://signage-repo-dc5s.vercel.app"
E2E_USERNAME=""
E2E_PASSWORD=""
